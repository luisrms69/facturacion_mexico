{
 "doctype": "DocType",
 "name": "Regla Impuesto CFDI Recibido",
 "module": "CFDI Recibidos",
 "custom": 0,
 "istable": 1,
 "editable_grid": 1,
 "engine": "InnoDB",
 "fields": [
  {
   "fieldname": "impuesto_sat",
   "label": "Código SAT",
   "fieldtype": "Select",
   "options": "002\n001\n003",
   "reqd": 1,
   "in_list_view": 1,
   "description": "002=IVA, 001=ISR, 003=IEPS"
  },
  {
   "fieldname": "tipo_factor",
   "label": "Tipo Factor",
   "fieldtype": "Select",
   "options": "\nTasa\nCuota",
   "in_list_view": 1,
   "description": "Tasa=porcentaje, Cuota=monto por unidad. Dejar vacío para retenciones (no aplica)."
  },
  {
   "fieldname": "tasa_cuota",
   "label": "Tasa",
   "fieldtype": "Float",
   "precision": "6",
   "in_list_view": 1,
   "description": "Valor exacto del XML SAT (ej: 0.160000 = IVA 16%). 0 para IEPS (coincide con cualquier tasa) y retenciones (no aplica)."
  },
  {
   "fieldname": "descripcion",
   "label": "Descripción",
   "fieldtype": "Data",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "es_retencion",
   "label": "Es Retención",
   "fieldtype": "Check",
   "default": "0",
   "in_list_view": 1,
   "description": "Marcado = Deduct (retención ISR/IVA). Sin marcar = Add (traslado acreditable)."
  },
  {
   "fieldname": "cuenta_impuesto",
   "label": "Cuenta Contable",
   "fieldtype": "Link",
   "options": "Account",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "activo",
   "label": "Activo",
   "fieldtype": "Check",
   "default": "1",
   "in_list_view": 1
  }
 ]
}
