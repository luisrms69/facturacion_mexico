  },
  {
   "fieldname": "col_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "supplier_rfc",
   "label": "RFC Proveedor",
   "fieldtype": "Data",
   "description": "Vacio = aplica a cualquier proveedor"
